# Токен бота от @BotFather
BOT_TOKEN=

# Интервал опроса бирж в секундах (± случайный разброс, см. watcher.py)
POLL_INTERVAL=300

# Путь к базе SQLite
DB_PATH=bot.db

# Чат, который регистрируется автоматически при старте (опционально)
SEED_CHAT_ID=

# Бесплатный ключ Groq (console.groq.com) для генерации черновиков откликов
# по кнопке. Если не задан — кнопка "Черновик отклика" просто отвечает,
# что функция не настроена.
GROQ_API_KEY=
